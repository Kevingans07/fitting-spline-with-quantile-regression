### --- QUANTIFY ACCURACY AND PRECISION ---
for (tau in taus) {
cat("\n=== Quantile tau =", tau, "===\n")
# Get true quantile
if (tau == 0.1) true_q <- true_q10
if (tau == 0.5) true_q <- true_q50
if (tau == 0.9) true_q <- true_q90
# Calculate fitted values for all sims
fitted_vals_all <- matrix(NA, nrow = n_sims, ncol = length(x))
for (sim in 1:n_sims) {
fitted_vals_all[sim, ] <- X %*% all_fits[sim, , as.character(tau)]
}
# Mean fitted values
mean_fitted <- colMeans(fitted_vals_all)
# ACCURACY: Bias (how far is mean estimate from truth?)
bias <- mean(mean_fitted - true_q)
rmse_from_truth <- sqrt(mean((mean_fitted - true_q)^2))
cat("Bias (mean error from truth):", round(bias, 4), "\n")
cat("RMSE from true quantile:", round(rmse_from_truth, 4), "\n")
# PRECISION: Variability across simulations
pointwise_sd <- apply(fitted_vals_all, 2, sd)
mean_sd <- mean(pointwise_sd)
cat("Mean standard deviation across sims:", round(mean_sd, 4), "\n")
cat("Precision (smaller is better): ", round(mean_sd, 4), "\n")
# Coverage: how often does truth fall within ±1 SD?
lower <- mean_fitted - pointwise_sd
upper <- mean_fitted + pointwise_sd
coverage <- mean(true_q >= lower & true_q <= upper)
cat("Coverage (% of x where truth is within ±1 SD):", round(100*coverage, 1), "%\n")
}
### --- TO CHECK ACCURACY AND PRECISION ---
